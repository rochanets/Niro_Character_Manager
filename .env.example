# Cole aqui a sua chave do Google AI Studio (https://aistudio.google.com/apikey)
GOOGLE_AI_API_KEY=
# Modelo usado no preenchimento por IA
GOOGLE_AI_MODEL=gemini-flash-latest
# (Hospedagem on-line) Diretório persistente para o banco e as imagens.
# No Railway, aponte para o mount path do volume (ex.: /data). Deixe em branco
# no uso local para manter o banco na raiz e as imagens em static/uploads.
DATA_DIR=
